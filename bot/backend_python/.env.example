# Server Configuration
PORT=3000
FLASK_ENV=development

# JWT Configuration
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRES_IN=86400

# MongoDB Configuration
# Local:
MONGODB_URI=mongodb://localhost:27017/ikora
# Atlas (production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ikora

# AI — pick one
# Gemini (free): https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# CORS (set to your Netlify URL in production)
FRONTEND_URL=http://localhost:8080
